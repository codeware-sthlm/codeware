{
  "name": "storybook",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/storybook/src",
  "projectType": "application",
  "tags": ["scope:storybook", "type:app"],
  "targets": {
    "storybook": {
      "executor": "@nx/storybook:storybook",
      "options": {
        "port": 6006,
        "configDir": "apps/storybook/.storybook"
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      },
      "syncGenerators": ["dev-plugin:theme-sync"]
    },
    "build-storybook": {
      "executor": "@nx/storybook:build",
      "outputs": ["{options.outputDir}"],
      "options": {
        "outputDir": "dist/storybook",
        "configDir": "apps/storybook/.storybook"
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      },
      "syncGenerators": ["dev-plugin:theme-sync"]
    },
    "chromatic": {
      "executor": "nx:run-commands",
      "dependsOn": ["build-storybook"],
      "options": {
        "command": "chromatic --no-interactive --config-file apps/storybook/chromatic.config.json"
      }
    }
  }
}
