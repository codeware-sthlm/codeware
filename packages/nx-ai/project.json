{
  "name": "nx-ai",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/nx-ai/src",
  "tags": ["scope:nx-ai", "type:plugin"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "options": {
        "assets": [
          "packages/nx-ai/*.md",
          {
            "input": "./packages/nx-ai/src",
            "glob": "**/!(*.ts)",
            "ignore": ["**/*.snap"],
            "output": "./src"
          },
          {
            "input": "./packages/nx-ai/src",
            "glob": "**/*.d.ts",
            "output": "./src"
          },
          {
            "input": "./packages/nx-ai",
            "glob": "**/*.json",
            "ignore": ["**/tsconfig*.json", "project.json"],
            "output": "."
          }
        ]
      }
    }
  }
}
